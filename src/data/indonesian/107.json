{
  "surah": 107,
  "name": "Al-Ma'un",
  "translator": "Kementerian Agama RI",
  "total_ayah": 7,
  "ayahs": [
    {
      "number": 1,
      "text": "Tahukah kamu (orang) yang mendustakan agama?"
    },
    {
      "number": 2,
      "text": "Maka itulah orang yang menghardik anak yatim,"
    },
    {
      "number": 3,
      "text": "dan tidak mengajak memberi makan orang miskin."
    },
    {
      "number": 4,
      "text": "Maka celakalah orang yang salat,"
    },
    {
      "number": 5,
      "text": "(yaitu) orang-orang yang lalai terhadap salatnya,"
    },
    {
      "number": 6,
      "text": "yang berbuat riya`,"
    },
    {
      "number": 7,
      "text": "dan enggan (memberikan) bantuan."
    }
  ]
}
