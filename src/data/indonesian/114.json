{
  "surah": 114,
  "name": "An-Nas",
  "translator": "Kementerian Agama RI",
  "total_ayah": 6,
  "ayahs": [
    {
      "number": 1,
      "text": "Katakanlah, \"Aku berlindung kepada Tuhannya manusia"
    },
    {
      "number": 2,
      "text": "Raja manusia"
    },
    {
      "number": 3,
      "text": "sembahan manusia"
    },
    {
      "number": 4,
      "text": "dari kejahatan (bisikan) setan yang bersembunyi"
    },
    {
      "number": 5,
      "text": "yang membisikkan (kejahatan) ke dalam dada manusia"
    },
    {
      "number": 6,
      "text": "dari (golongan) jin dan manusia"
    }
  ]
}
